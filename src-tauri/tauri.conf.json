{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Hot Sheet",
  "version": "0.7.0",
  "identifier": "com.brianwestphal.hotsheet",
  "build": {
    "beforeDevCommand": "npm run build:client",
    "frontendDist": "loading"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hot Sheet",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/hotsheet-node"
    ],
    "resources": [
      "server/**/*",
      "resources/hotsheet",
      "resources/hotsheet-linux",
      "resources/hotsheet.cmd",
      "icons/variants/*.png",
      "icons/variants/*.icns"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFEMDk4QTJDNjRGODQ1RkEKUldUNlJmaGtMSW9KcmJmcmMvYlpaeEVQNlg1M3hUOThPckVmT3ZMYndQWjNQMitVN3JZTGc1TSsK",
      "endpoints": [
        "https://github.com/brianwestphal/hotsheet/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
