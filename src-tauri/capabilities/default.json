{
  "identifier": "default",
  "description": "Default permissions for Hot Sheet",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/hotsheet-node",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "updater:default",
    "process:default",
    "notification:default"
  ]
}
